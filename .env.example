PRIVATE_KEY=replace_with_wallet_private_key
FUNDER_ADDRESS=replace_with_funder_address_if_needed
POLY_SIGNATURE_TYPE=0
POLY_CHAIN_ID=137
POLY_HOST=https://clob.polymarket.com
POLY_WS_URL=wss://clob.polymarket.com/ws/market
GAMMA_API_URL=https://gamma-api.polymarket.com
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
TARGET_SYMBOLS=BTC,ETH,SOL
TARGET_WINDOWS_MINUTES=5,15
DEFAULT_ORDER_SIZE=5
MIN_ENTRY_EDGE=0.035
MIN_EXIT_EDGE=0.02
MIN_HEDGE_MARGIN=0.03
MAX_POSITION_PER_MARKET=15
MAX_OPEN_MARKETS=20
SCAN_INTERVAL_SECONDS=30
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_CHAT_ID=replace_with_telegram_chat_id
TELEGRAM_REPORT_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
LOG_DIR=/logs
LOG_FILE=trader.log
DATA_DIR=/data
DB_NAME=hail.db
EST_ANNUAL_VOL_BTC=0.6
EST_ANNUAL_VOL_ETH=0.75
EST_ANNUAL_VOL_SOL=1.0
REQUEST_TIMEOUT_SECONDS=15
